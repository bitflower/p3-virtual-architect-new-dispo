    {
      "id": "vAs6-cPPSHsjGHsOamXlu",
      "type": "text",
      "x": 15204.830477776091,
      "y": 4276.789683981754,
      "width": 1845.6385498046875,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
